---
export interface Props {
  label?: string;
  title: string;
  description?: string;
}

const { label, title, description } = Astro.props;
---

<div class="section-title reveal">
  {label && <span class="section-title__label">{label}</span>}
  <h2>{title}</h2>
  {description && <p>{description}</p>}
</div>
