# 创建 .gitignore 文件
cat > .gitignore << EOF
# 依赖目录
node_modules/
# package-lock.json
yarn.lock
pnpm-lock.yaml

# 环境变量
.env
.env.local
.env.*.local

# 日志文件
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 构建产物
dist/
build/
out/
.next/
.nuxt/

# 缓存目录
.cache/
.parcel-cache/
.turbo/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db

# 测试覆盖率
coverage/
.nyc_output/

# 其他
*.tmp
*.temp
EOF